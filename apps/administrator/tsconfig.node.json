{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "noEmit": false,
    "outDir": "./dist-node",
    "declaration": true
  },
  "include": ["vite.config.ts", "server/**/*.ts"],
  "exclude": ["server/**/*.test.ts"]
}

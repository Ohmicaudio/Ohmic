# Local repo mirrors / working clones do not belong in the umbrella repo.
/repos/

# Generated context can be rebuilt.
/generated/ai-index/*
/generated/context-index/*
/generated/agent-work/*
!.gitkeep

# Local job claim files are coordination exhaust, not canonical history.
/agent-system/jobs/active/*.md
/agent-system/jobs/completed/*.md
!/agent-system/jobs/active/.gitkeep
!/agent-system/jobs/completed/.gitkeep

# Local harvest payloads are retained for reference, not committed as source.
/harvest/
/ohmic-audio-universe-db-reference/
/ohmic-audio-universe/
/tools/semantic-index/__pycache__/

# OS/editor noise
.DS_Store
Thumbs.db
desktop.ini

# Local tool state and generated review artifacts do not belong in the repo.
/.claude/
/.playwright-cli/
/output/
